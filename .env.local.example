# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Twilio — used ONLY for outbound order-notification SMS (accept,
# ready, completed, decline). Signup OTPs go through Twilio Verify,
# but Supabase Auth calls Verify on our behalf, so the Verify Service
# SID lives in the Supabase dashboard (Authentication → Providers →
# Phone), NOT here. Do not re-add TWILIO_VERIFY_SERVICE_SID — it's
# unread by app code and any value here will silently mislead.
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Push + SMS Notifications (OneSignal)
ONESIGNAL_APP_ID=your-app-id
ONESIGNAL_REST_API_KEY=your-rest-api-key

# Payments (Stripe)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PLATFORM_FEE_PERCENT=10

# Media (Cloudinary)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Anthropic (AI description assistant)
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override model (defaults to claude-sonnet-4-5)
# ANTHROPIC_MODEL=claude-sonnet-4-5

# Beta signup webhook — every signup attempt fires a real-time ping
# so an operator has visibility into who's onboarding. Originally
# added during the A2P 10DLC wait so we could manually deliver OTPs;
# now that signup OTPs route through Twilio Verify (10DLC-exempt),
# this is operational telemetry rather than a workaround. Leave unset
# to disable (silent no-op). Setup: api.slack.com/apps → New App →
# Incoming Webhooks → Add to Workspace → pick channel → copy URL.
BETA_SIGNUP_WEBHOOK_URL=https://hooks.slack.com/services/...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
