# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Twilio (OTP + SMS Messaging)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_VERIFY_SERVICE_SID=your-verify-service-sid
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Push + SMS Notifications (OneSignal)
ONESIGNAL_APP_ID=your-app-id
ONESIGNAL_REST_API_KEY=your-rest-api-key

# Payments (Stripe)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PLATFORM_FEE_PERCENT=5

# Media (Cloudinary)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Anthropic (AI description assistant)
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override model (defaults to claude-sonnet-4-5)
# ANTHROPIC_MODEL=claude-sonnet-4-5

# Beta signup notification email (via Resend) — every signup attempt
# triggers an email to the admin address while Twilio A2P 10DLC is
# pending. Leave RESEND_API_KEY unset to disable in dev (silent no-op).
# Sign up + grab key: https://resend.com/api-keys
RESEND_API_KEY=re_...
# Where the notification lands (default: admin@kder.org)
BETA_SIGNUP_EMAIL_TO=admin@kder.org
# Sender. Use "onboarding@resend.dev" until kder.org is verified in
# Resend → Domains, then switch back to a kder.org address.
BETA_SIGNUP_EMAIL_FROM=notifications@kder.org

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
